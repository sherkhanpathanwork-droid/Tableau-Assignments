  <worksheets>
    <worksheet name='Q1'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>Q1 </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>What is a Calculated Field and why is it important in business dashboards?</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Answer :</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> A </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Calculated Field</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> in Tableau is a custom field created using formulas based on existing data. It allows analysts to generate new metrics or transform raw data into meaningful insights.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Why it is important:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Helps create </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>custom KPIs</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> (e.g., Profit, Profit Margin) </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Converts raw data into </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>actionable insights</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Reduces manual calculations </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Enables </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>dynamic and automated analysis</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Improves decision-making in dashboards </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Example:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Profit = Sales – Cost </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Profit Margin = Profit / Sales</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources />
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='header'>
            <format attr='height-header' value='124' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
          </pane>
        </panes>
        <rows />
        <cols />
      </table>
      <simple-id uuid='{D3B6A3B0-BC9C-4EAA-AE9A-0EE99C84AB9E}' />
    </worksheet>
    <worksheet name='Q2'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Q2</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> .Why can’t parameters change visuals directly in Tableau?</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Answe</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>r: Parameters in Tableau act as input variables, but they do not directly affect visuals because they are not tied to the data by default.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>To impact visuals, parameters must be used in:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Calculated Fields </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Filters </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Reference Lines</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources />
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
          </pane>
        </panes>
        <rows />
        <cols />
      </table>
      <simple-id uuid='{442E6111-EC83-473D-A7BB-5969079D6640}' />
    </worksheet>
    <worksheet name='Q3'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>Q3.</run>
            <run>Æ </run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>When should EXCLUDE LOD be used?</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Answer:</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> The EXCLUDE LOD expression is used when you want to remove a specific dimension from the level of detail in a calculation.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Æ  </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'> When to use:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>When you want higher-level aggregation </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>When you need to ignore certain dimensions in the view </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>For comparisons across levels</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources />
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
          </pane>
        </panes>
        <rows />
        <cols />
      </table>
      <simple-id uuid='{D40CC4F5-8C87-4E62-9771-B4E319A8A67A}' />
    </worksheet>
    <worksheet name='Q4'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Q4</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> .Difference between FIXED and INCLUDE LOD expressions?</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Answer:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Æ    </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'> Fixed Lod :</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Computes values at a specified level of detail, independent of the view </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Ignores filters (except context filters) </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Example:</run>
            <run>Æ&#10;</run>
            <run auto-url='true' fontcolor='#000000' fontname='Courier New' hyperlink='tabdoc:load-url url=&amp;quot;(FIXED [CITY] : AVG(SALES) )&amp;quot;'>(FIXED [CITY] : AVG(SALES) )</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Always calculates average sales per city</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>  Include Lod :</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Adds additional dimensions to the calculation </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Works based on the dimensions present in the view </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Example:</run>
            <run>Æ&#10;</run>
            <run auto-url='true' fontcolor='#000000' fontname='Courier New' hyperlink='tabdoc:load-url url=&amp;quot;{&amp;quot;'>{</run>
            <run fontcolor='#000000' fontname='Courier New'> INCLUDE [Product Name] : AVG(Sales) }</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Calculates at product level, then aggregates up</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources />
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
          </pane>
        </panes>
        <rows />
        <cols />
      </table>
      <simple-id uuid='{96590744-1C38-4216-B740-8DB1D3730133}' />
    </worksheet>
    <worksheet name='Task1'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>Task 1: Delivery Performance Classification (Calculated Field)Business Need Operations wants to track delivery efficiency. Task Classify orders as Fast or Delayed. </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>Condition :</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>Delivery ≤ 30 min → Fast </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>Else → Delayed  </run>
            <run>
calculated field created as name : delivery status</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Blinkit Orders Dataset)' name='federated.063jyag07mck7n16xjz1y0k2wmvi' />
          </datasources>
          <datasource-dependencies datasource='federated.063jyag07mck7n16xjz1y0k2wmvi'>
            <column caption='Delivery status' datatype='string' name='[Calculation_0202369451638784]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Delivery_Time_Min] &lt;= 30 THEN &quot;Fast&quot;&#13;&#10;ELSE &quot;Delayed&quot;&#13;&#10;END' />
            </column>
            <column caption='Delivery Time Min' datatype='integer' name='[Delivery_Time_Min]' role='measure' type='quantitative' />
            <column caption='Order ID' datatype='integer' name='[Order_ID]' role='dimension' type='ordinal' />
            <column-instance column='[Order_ID]' derivation='Count' name='[cnt:Order_ID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0202369451638784]' derivation='None' name='[none:Calculation_0202369451638784:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <color column='[federated.063jyag07mck7n16xjz1y0k2wmvi].[none:Calculation_0202369451638784:nk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.063jyag07mck7n16xjz1y0k2wmvi].[cnt:Order_ID:qk]</rows>
        <cols />
      </table>
      <simple-id uuid='{529F1F43-0C42-4243-827E-A72C8DFA2E37}' />
    </worksheet>
    <worksheet name='Task2'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>Task 2</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>: Loss-Making Orders Identification </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>Business Need :</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>High sales do not always mean high profit. </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>Task:</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'> Identify orders resulting in loss</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>Loss Flag :</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'><![CDATA[     IF [Profit] < 0 THEN "LOSS"]]></run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>      ELSE &quot;PROFIT&quot;</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>      END</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources />
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
          </pane>
        </panes>
        <rows />
        <cols />
      </table>
      <simple-id uuid='{214D65C1-5D21-4E36-BBF3-9920D98784E5}' />
    </worksheet>
    <worksheet name='Task3'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Task 3: </run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Top N Products Analysis (Parameter) </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Business Need</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>: The product team wants to focus on top-performing products. </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Task :</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Create a Top N Products dynamic analysis</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Blinkit Orders Dataset)' name='federated.063jyag07mck7n16xjz1y0k2wmvi' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Top N' datatype='real' name='[Parameter 1]' param-domain-type='range' role='measure' type='quantitative' value='5.0'>
              <calculation class='tableau' formula='5.0' />
              <range granularity='1.0' max='20.0' min='1.0' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.063jyag07mck7n16xjz1y0k2wmvi'>
            <column caption='Top N Filter' datatype='boolean' name='[Calculation_0202369454477315]' role='measure' type='nominal'>
              <calculation class='tableau' formula='RANK(SUM([Sales]))  &lt;= [Parameters].[Parameter 1]'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Product Name' datatype='string' name='[Product_Name]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Sales]' role='measure' type='quantitative' />
            <column-instance column='[Product_Name]' derivation='None' name='[none:Product_Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Sales]' derivation='Sum' name='[sum:Sales:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0202369454477315]' derivation='User' name='[usr:Calculation_0202369454477315:nk:1]' pivot='key' type='nominal'>
              <table-calc ordering-type='Columns' />
            </column-instance>
          </datasource-dependencies>
          <filter class='categorical' column='[federated.063jyag07mck7n16xjz1y0k2wmvi].[usr:Calculation_0202369454477315:nk:1]'>
            <groupfilter function='member' level='[usr:Calculation_0202369454477315:nk:1]' member='true' user:ui-domain='relevant' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.063jyag07mck7n16xjz1y0k2wmvi].[usr:Calculation_0202369454477315:nk:1]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
          </pane>
        </panes>
        <rows>[federated.063jyag07mck7n16xjz1y0k2wmvi].[none:Product_Name:nk]</rows>
        <cols>[federated.063jyag07mck7n16xjz1y0k2wmvi].[sum:Sales:qk]</cols>
      </table>
      <simple-id uuid='{9A3AB2FC-905B-497E-B91B-F0E0BD7E2C59}' />
    </worksheet>
    <worksheet name='Task4'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>Task 4</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>: City-Level Benchmarking (FIXED LOD) </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>Business Need</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>: Compare city performance independent of category filters. </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>Task</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>: Calculate average sales per city using FIXED LOD.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='14'>            : -   { FIXED [City] : AVG([Sales]) }</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Blinkit Orders Dataset)' name='federated.063jyag07mck7n16xjz1y0k2wmvi' />
          </datasources>
          <datasource-dependencies datasource='federated.063jyag07mck7n16xjz1y0k2wmvi'>
            <column caption='Avg Sales per City' datatype='real' name='[Calculation_0202369455353860]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [City] : AVG([Sales]) }' />
            </column>
            <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
            <column datatype='integer' name='[Sales]' role='measure' type='quantitative' />
            <column-instance column='[City]' derivation='None' name='[none:City:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0202369455353860]' derivation='Sum' name='[sum:Calculation_0202369455353860:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
          </pane>
        </panes>
        <rows>[federated.063jyag07mck7n16xjz1y0k2wmvi].[none:City:nk]</rows>
        <cols>[federated.063jyag07mck7n16xjz1y0k2wmvi].[sum:Calculation_0202369455353860:qk]</cols>
      </table>
      <simple-id uuid='{F634DF56-64E0-48F6-A8AA-73AB9133F44C}' />
    </worksheet>
    <worksheet name='Task5'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Task 5:</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> Customer/Product Detail Impact (INCLUDE LOD) </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Business Need</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>: The sales team wants average sales considering product-level detail, even when product is not shown. </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Task:</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> Create a calculation that finds the average sales at the product level, but allows the result to be used at a higher level (such as Category or Region). </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Use INCLUDE LOD</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Blinkit Orders Dataset)' name='federated.063jyag07mck7n16xjz1y0k2wmvi' />
          </datasources>
          <datasource-dependencies datasource='federated.063jyag07mck7n16xjz1y0k2wmvi'>
            <column caption='Product Avg Sales' datatype='real' name='[Calculation_0202369456009221]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ INCLUDE [Product_Name] : AVG([Sales]) }' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column caption='Product Name' datatype='string' name='[Product_Name]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Sales]' role='measure' type='quantitative' />
            <column-instance column='[Category]' derivation='None' name='[none:Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0202369456009221]' derivation='Sum' name='[sum:Calculation_0202369456009221:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
          </pane>
        </panes>
        <rows>[federated.063jyag07mck7n16xjz1y0k2wmvi].[none:Category:nk]</rows>
        <cols>[federated.063jyag07mck7n16xjz1y0k2wmvi].[sum:Calculation_0202369456009221:qk]</cols>
      </table>
      <simple-id uuid='{70733BB1-15CB-47B8-B45D-6C7E835B951D}' />
    </worksheet>
  </worksheets>
